{
  "version": 2,
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "routes": [
    { "src": "/admin", "status": 404, "dest": "/404.html" },
    { "src": "/admin/login", "status": 404, "dest": "/404.html" },
    { "src": "/admin/(.*)", "status": 404, "dest": "/404.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
